# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Google
GOOGLE_PLACES_API_KEY=your_key_here

# OpenWeatherMap
OPENWEATHER_API_KEY=your_key_here

# Data.gov.sg — REQUIRED for NEA hygiene grades
# Free registration at https://data.gov.sg/developer
# Without this key all hygiene grades show as UNKNOWN (unauthenticated rate limit is too low)
DATAGOV_API_KEY=your_key_here

# App config
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
